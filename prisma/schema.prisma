generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_0jHvzLnFsq3Z@ep-bold-dream-adrvs0j6-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
}

// ----- Utilisateur / Admin -----
model User {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  password     String?
  role         Role         @default(USER)
  createdAt    DateTime     @default(now())

  contacts     Contact[]
  skills       Skill[]
  certificates Certificate[]
}

enum Role {
  USER
  ADMIN
}

// ----- Projets -----
model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  img         String
  live        String?
  github      String?
  createdAt   DateTime @default(now())
}

// ----- Services -----
model Service {
  id          Int      @id @default(autoincrement())
  num         String
  title       String
  description String
  href        String?
}

// ----- Expérience -----
model Experience {
  id        Int      @id @default(autoincrement())
  company   String
  position  String
  duration  String
}

// ----- Education -----
model Education {
  id          Int      @id @default(autoincrement())
  institution String
  position    String
  duration    String
}

// ----- Contact / Messages -----
model Contact {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  service   String?
  message   String
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

// ----- Skills -----
model Skill {
  id        Int      @id @default(autoincrement())
  name      String
  level     Level
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

enum Level {
  Beginner
  Intermediate
  Advanced
  Expert
}

// ----- Certificates -----
model Certificate {
  id        Int      @id @default(autoincrement())
  title     String
  issuer    String
  date      DateTime
  url       String?
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

// ----- Testimonials -----
model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  role      String?
  content   String
  createdAt DateTime @default(now())
}
